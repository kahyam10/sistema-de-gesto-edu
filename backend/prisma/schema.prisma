// Prisma Schema - Sistema de Gestão Educacional
// Banco: PostgreSQL (Supabase - Produção)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTENTICAÇÃO ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nome      String
  role      String   @default("RESPONSAVEL") // ADMIN, SEMEC, DIRETOR, COORDENADOR, SECRETARIA, PROFESSOR, RESPONSAVEL
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos para vinculação específica
  escolaId        String?
  escola          Escola? @relation(fields: [escolaId], references: [id])

  profissionalId  String?              @unique
  profissional    ProfissionalEducacao? @relation(fields: [profissionalId], references: [id])

  matriculaId     String?              @unique
  matricula       Matricula?           @relation(fields: [matriculaId], references: [id])

  refreshTokens   RefreshToken[]

  @@map("users")
}

// ==================== REFRESH TOKENS ====================

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== ESTRUTURA ACADÊMICA ====================

model Serie {
  id        String   @id @default(cuid())
  nome      String
  ordem     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  etapaId String
  etapa   EtapaEnsino @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  turmas  Turma[]

  @@map("series")
}

model EtapaEnsino {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ordem     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  series     Serie[]
  escolas    EscolaEtapa[]
  matriculas Matricula[]
  disciplinas Disciplina[]
  configuracoes ConfiguracaoAvaliacao[]

  // Módulo 9: Comunicação e Eventos
  comunicados Comunicado[]

  @@map("etapas_ensino")
}

model Escola {
  id              String   @id @default(cuid())
  nome            String
  codigo          String   @unique
  endereco        String?
  telefone        String?
  email           String?
  quantidadeSalas Int      @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Infraestrutura - Áreas comuns
  possuiPatio         Boolean @default(false)
  possuiParque        Boolean @default(false)
  possuiQuadra        Boolean @default(false)
  quadraCoberta       Boolean @default(false)
  possuiBiblioteca    Boolean @default(false)
  possuiRefeitorio    Boolean @default(false)
  possuiSalaProfessores Boolean @default(false)
  possuiSecretaria    Boolean @default(false)
  possuiDiretoria     Boolean @default(false)
  possuiAlmoxarifado  Boolean @default(false)
  possuiCozinha       Boolean @default(false)
  possuiDispensa      Boolean @default(false)
  
  // Infraestrutura - Banheiros
  qtdBanheirosAlunos      Int @default(0)
  qtdBanheirosAlunas      Int @default(0)
  qtdBanheirosAdaptados   Int @default(0)
  qtdBanheirosFuncionarios Int @default(0)
  
  // Infraestrutura - Tecnologia
  possuiInternet        Boolean @default(false)
  tipoInternet          String? // FIBRA, CABO, RADIO, SATELITE
  velocidadeInternet    String? // Ex: "100 Mbps"
  possuiSalaInformatica Boolean @default(false)
  qtdComputadores       Int     @default(0)
  possuiProjetores      Boolean @default(false)
  qtdProjetores         Int     @default(0)
  
  // Infraestrutura - Acessibilidade
  possuiRampaAcesso     Boolean @default(false)
  possuiElevador        Boolean @default(false)
  possuiPisoTatil       Boolean @default(false)
  possuiSinalizacaoBraile Boolean @default(false)

  // Relacionamentos
  etapas       EscolaEtapa[]
  turmas       Turma[]
  matriculas   Matricula[]
  profissionais EscolaProfissional[]
  users        User[]
  salas        Sala[]
  eventosCalendario EventoCalendario[]
  configuracoes ConfiguracaoAvaliacao[]

  // Módulo 5: Programas Especiais
  buscasAtivas        BuscaAtiva[]
  salasRecursos       SalaRecursos[]
  acompanhamentos     AcompanhamentoIndividualizado[]

  // Módulo 9: Comunicação e Eventos
  plantoesPedagogicos PlantaoPedagogico[] @relation("PlantaoEscola")
  reunioesPais        ReuniaoPais[] @relation("ReuniaoEscola")
  comunicados         Comunicado[] @relation("ComunicadoEscola")

  @@map("escolas")
}

// ==================== SALAS DA ESCOLA ====================

model Sala {
  id               String   @id @default(cuid())
  nome             String   // Ex: "Sala 01", "Sala de Leitura", "Laboratório"
  tipo             String   // AULA, INFORMATICA, LEITURA, LABORATORIO, MULTIUSO, AEE
  capacidade       Int      @default(25)
  possuiArCondicionado Boolean @default(false)
  possuiVentilador Boolean @default(false)
  possuiTV         Boolean @default(false)
  possuiProjetor   Boolean @default(false)
  possuiQuadro     Boolean @default(true) // Quadro branco/verde
  metragem         Float?   // Área em m²
  andar            Int      @default(0) // 0 = térreo
  acessivel        Boolean  @default(true) // Acessível para cadeirantes
  ativo            Boolean  @default(true)
  observacoes      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relacionamentos
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  @@map("salas")
}

// Tabela de junção: Escola <-> EtapaEnsino (N:M)
model EscolaEtapa {
  id        String   @id @default(cuid())
  escolaId  String
  etapaId   String
  createdAt DateTime @default(now())

  escola Escola      @relation(fields: [escolaId], references: [id], onDelete: Cascade)
  etapa  EtapaEnsino @relation(fields: [etapaId], references: [id], onDelete: Cascade)

  @@unique([escolaId, etapaId])
  @@map("escolas_etapas")
}

model Turma {
  id               String   @id @default(cuid())
  nome             String
  turno            String   // MATUTINO, VESPERTINO, NOTURNO, INTEGRAL
  anoLetivo        Int
  capacidadeMaxima Int      @default(25)
  limitePCD        Int      @default(3)
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relacionamentos
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)
  
  serieId String
  serie   Serie @relation(fields: [serieId], references: [id], onDelete: Cascade)

  matriculas    Matricula[]
  professores   TurmaProfessor[]
  horarios      GradeHoraria[]
  frequencias   Frequencia[]
  avaliacoes    Avaliacao[]
  notas         Nota[]

  // Módulo 9: Comunicação e Eventos
  plantoesPedagogicos PlantaoPedagogico[]
  reunioesPais        ReuniaoPais[]
  comunicados         Comunicado[]

  @@map("turmas")
}

// ==================== MATRÍCULAS ====================

model Matricula {
  id                String   @id @default(cuid())
  numeroMatricula   String   @unique
  anoLetivo         Int
  status            String   @default("ATIVA") // ATIVA, TRANSFERIDA, CANCELADA, CONCLUIDA
  dataMatricula     DateTime @default(now())
  
  // Dados do Aluno
  nomeAluno         String
  dataNascimento    DateTime
  cpfAluno          String?
  rgAluno           String?
  sexo              String   // M, F
  naturalidade      String?
  nacionalidade     String   @default("Brasileira")
  corRaca           String?
  
  // Necessidades Especiais
  possuiDeficiencia Boolean  @default(false)
  tipoDeficiencia   String?
  
  // Dados do Responsável
  nomeResponsavel   String
  cpfResponsavel    String?
  telefoneResponsavel String?
  emailResponsavel  String?
  parentesco        String?
  
  // Endereço
  endereco          String?
  bairro            String?
  cidade            String?
  estado            String?
  cep               String?
  
  // Documentos e Observações
  documentosEntregues String?  // JSON string com lista de documentos
  observacoes       String?

  // Arquivos de Documentos (paths)
  fotoAluno              String?  // Path para foto 3x4
  documentoRG            String?  // Path para RG digitalizado
  documentoCPF           String?  // Path para CPF digitalizado
  comprovanteResidencia  String?  // Path para comprovante
  certidaoNascimento     String?  // Path para certidão
  historicoEscolar       String?  // Path para histórico/transferência
  outrosDocumentos       String?  // JSON com array de {nome, path}

  // Dados de Saude
  tipoSanguineo         String?  // A+, A-, B+, B-, AB+, AB-, O+, O-
  alergias              String?  // Texto livre com alergias
  medicamentos          String?  // Medicamentos de uso continuo
  condicoesSaude        String?  // Condicoes de saude relevantes
  planoSaude            String?  // Nome do plano de saude
  numeroCartaoSUS       String?  // Numero do Cartao SUS

  // Contatos de Emergencia
  contatoEmergenciaNome       String?
  contatoEmergenciaTelefone   String?
  contatoEmergenciaParentesco String?

  // Autorizacoes
  autorizacaoImagem     Boolean  @default(false)
  autorizacaoSaida      Boolean  @default(false)
  pessoasAutorizadasRetirar String? // JSON com array de {nome, parentesco, telefone}

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relacionamentos
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id])
  
  etapaId String
  etapa   EtapaEnsino @relation(fields: [etapaId], references: [id])
  
  turmaId String?
  turma   Turma? @relation(fields: [turmaId], references: [id])

  frequencias Frequencia[]
  notas       Nota[]
  user        User?

  // Módulo 5: Programas Especiais
  buscasAtivas   BuscaAtiva[]
  pei            PlanoEducacionalIndividualizado?
  acompanhamentos AcompanhamentoIndividualizado[]

  // Módulo 9: Comunicação e Eventos
  presencasReunioes PresencaReuniao[]

  @@map("matriculas")
}

// ==================== PROFISSIONAIS ====================

model ProfissionalEducacao {
  id            String   @id @default(cuid())
  nome          String
  cpf           String   @unique
  email         String?
  telefone      String?
  tipo          String   // PROFESSOR, AUXILIAR, COORDENADOR, DIRETOR
  formacao      String?  // Campo legado - manter compatibilidade
  especialidade String?
  matricula     String?  @unique
  ativo         Boolean  @default(true)

  // Dados adicionais
  dataNascimento     DateTime?
  dataAdmissao       DateTime?  // Data de admissão na rede
  regimeContratacao  String?    // EFETIVO, CONTRATADO, TEMPORARIO, TERCEIRIZADO, CEDIDO
  escolaridade       String?    // FUNDAMENTAL, MEDIO, SUPERIOR, POS_GRADUACAO, MESTRADO, DOUTORADO

  // RH - Jornada e dados bancários
  jornada            Int?       // Carga horária semanal total (horas)
  banco              String?    // Nome do banco
  agencia            String?    // Número da agência
  conta              String?    // Número da conta
  tipoConta          String?    // CORRENTE, POUPANCA
  pix                String?    // Chave PIX

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  escolas        EscolaProfissional[]
  turmas         TurmaProfessor[]
  formacoes      FormacaoProfissional[]
  certificacoes  CertificacaoProfissional[]
  historicoContratacoes HistoricoContratacao[]
  afastamentos   Afastamento[]
  horarios       GradeHoraria[]
  avaliacoes     Avaliacao[]
  pontos         Ponto[]
  licencas       Licenca[]
  user           User?

  // Módulo 5: Programas Especiais
  buscasAtivasResponsavel    BuscaAtiva[]
  atendimentosAEE            AtendimentoAEE[]
  acompanhamentosResponsavel AcompanhamentoIndividualizado[]

  // Módulo 9: Comunicação e Eventos
  reunioesPaisResponsavel ReuniaoPais[]
  comunicadosAutor        Comunicado[]

  @@map("profissionais_educacao")
}

// ==================== GRADE HORÁRIA ====================

model GradeHoraria {
  id            String   @id @default(cuid())
  diaSemana     String   // SEGUNDA, TERCA, QUARTA, QUINTA, SEXTA, SABADO
  horaInicio    String   // Ex: "07:30"
  horaFim       String   // Ex: "08:20"
  disciplina    String
  observacoes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  turmaId       String
  turma         Turma @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  profissionalId String?
  profissional   ProfissionalEducacao? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)

  @@index([turmaId])
  @@index([profissionalId])
  @@map("grade_horaria")
}

// Formações acadêmicas do profissional
model FormacaoProfissional {
  id              String   @id @default(cuid())
  profissionalId  String
  tipo            String   // GRADUACAO, POS_GRADUACAO, MESTRADO, DOUTORADO, CURSO_TECNICO, CURSO_LIVRE
  nome            String   // Ex: "Licenciatura em Pedagogia", "MBA em Gestão Escolar"
  instituicao     String?  // Ex: "UFBA", "UESC"
  anoConclusao    Int?     // Ano de conclusão
  cargaHoraria    Int?     // Carga horária (para cursos)
  emAndamento     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@map("formacoes_profissionais")
}

// Certificações e cursos complementares
model CertificacaoProfissional {
  id              String   @id @default(cuid())
  profissionalId  String
  nome            String   // Ex: "Certificação Google Educator", "Curso de Libras"
  instituicao     String?  // Instituição emissora
  dataEmissao     DateTime?
  dataValidade    DateTime? // Para certificações com validade
  cargaHoraria    Int?
  urlCertificado  String?  // Link para o certificado digital
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@map("certificacoes_profissionais")
}

// Histórico de contratações e vínculos
model HistoricoContratacao {
  id              String   @id @default(cuid())
  profissionalId  String
  tipo            String   // ADMISSAO, TRANSFERENCIA, PROMOCAO, REMANEJAMENTO, RESCISAO
  descricao       String   // Descrição do evento
  dataEvento      DateTime
  cargo           String?  // Cargo na época
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([profissionalId])
  @@map("historico_contratacoes")
}

// Afastamentos, licenças e atestados
model Afastamento {
  id              String   @id @default(cuid())
  profissionalId  String
  tipo            String   // ATESTADO_MEDICO, LICENCA_SAUDE, LICENCA_MATERNIDADE, FERIAS, OUTROS
  dataInicio      DateTime
  dataFim         DateTime?
  motivo          String?
  observacoes     String?
  documentoPath   String?  // Path para o documento (atestado digitalizado)
  ativo           Boolean  @default(true) // Se o afastamento está vigente
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([profissionalId])
  @@index([dataInicio, dataFim])
  @@map("afastamentos")
}

// Licenças (processo formal com aprovação)
model Licenca {
  id              String   @id @default(cuid())
  profissionalId  String
  tipo            String   // LICENCA_MEDICA, LICENCA_MATERNIDADE, LICENCA_PATERNIDADE, LICENCA_Premio, LICENCA_SEM_VENCIMENTO, FERIAS
  dataInicio      DateTime
  dataFim         DateTime
  diasCorridos    Int      // Número de dias corridos
  diasUteis       Int?     // Número de dias úteis (calculado)
  motivo          String?
  observacoes     String?
  status          String   @default("PENDENTE") // PENDENTE, APROVADA, REJEITADA, CANCELADA
  documentoPath   String?  // Path para o documento (atestado, requerimento)

  // Aprovação
  aprovadaPor     String?  // ID do usuário que aprovou
  dataAprovacao   DateTime?
  justificativaRejeicao String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([profissionalId])
  @@index([status])
  @@index([dataInicio, dataFim])
  @@map("licencas")
}

// Folha de Ponto Digital (registro de entrada/saída)
model Ponto {
  id              String   @id @default(cuid())
  profissionalId  String
  escolaId        String?  // Escola onde registrou o ponto
  data            DateTime // Data do registro (sem hora)
  entrada         String?  // Horário de entrada (ex: "07:30")
  saida           String?  // Horário de saída (ex: "12:00")
  entrada2        String?  // Segunda entrada (turno vespertino)
  saida2          String?  // Segunda saída

  // Cálculo automático
  horasTrabalhadas Float?  // Total de horas trabalhadas no dia

  // Observações
  tipoRegistro    String   @default("NORMAL") // NORMAL, ATESTADO, FALTA, FALTA_JUSTIFICADA, FERIAS, LICENCA
  observacoes     String?
  justificativa   String?  // Justificativa para atrasos/faltas

  // Localização (opcional - para controle)
  latitude        Float?
  longitude       Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([profissionalId])
  @@index([data])
  @@index([escolaId])
  @@map("pontos")
}

// Tabela de junção: Escola <-> ProfissionalEducacao (N:M)
// Representa lotação de profissionais em escolas
model EscolaProfissional {
  id              String   @id @default(cuid())
  escolaId        String
  profissionalId  String
  funcao          String?  // Função específica nesta escola
  cargaHoraria    Int?     // Carga horária semanal
  dataInicio      DateTime @default(now()) // Data de início da lotação
  dataFim         DateTime? // Data de fim (null = lotação ativa)
  ativo           Boolean  @default(true) // Se a lotação está ativa
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  escola       Escola               @relation(fields: [escolaId], references: [id], onDelete: Cascade)
  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([escolaId])
  @@index([profissionalId])
  @@index([ativo])
  @@map("escolas_profissionais")
}

// Tabela de junção: Turma <-> Profissional (N:M)
model TurmaProfessor {
  id             String   @id @default(cuid())
  turmaId        String
  profissionalId String
  tipo           String   // PROFESSOR, AUXILIAR
  disciplina     String?
  createdAt      DateTime @default(now())

  turma        Turma                @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  profissional ProfissionalEducacao @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@unique([turmaId, profissionalId])
  @@map("turmas_professores")
}

// ==================== MÓDULOS DO SISTEMA ====================

model Module {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("GraduationCap")
  phase       Int      @default(1)
  status      String   @default("planning") // planning, in-progress, completed, blocked
  progress    Int      @default(0)
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subModules SubModule[]

  @@map("modules")
}

model SubModule {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   @default("planning") // planning, in-progress, completed, blocked
  observacao  String?
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("sub_modules")
}

// ==================== CRONOGRAMA / FASES ====================

model Phase {
  id          String   @id @default(cuid())
  name        String
  description String
  monthRange  String   // Ex: "Meses 1-3"
  duration    String   // Ex: "3 meses"
  ordem       Int      @default(0)
  status      String   @default("planning") // planning, in-progress, completed, blocked
  moduleIds   String   // JSON array de IDs de módulos relacionados
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("phases")
}

// ==================== FREQUÊNCIA E AVALIAÇÕES ====================

model Frequencia {
  id             String   @id @default(cuid())
  data           DateTime // Data da aula/frequência
  status         String   // PRESENTE, FALTA, JUSTIFICADA
  justificativa  String?  // Justificativa para faltas justificadas
  observacao     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relacionamentos
  matriculaId    String
  matricula      Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  turmaId        String
  turma          Turma @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  // Índices para otimização
  @@index([matriculaId])
  @@index([turmaId])
  @@index([data])
  @@unique([matriculaId, turmaId, data]) // Um registro por aluno por turma por dia
  @@map("frequencias")
}

// ==================== CALENDÁRIO LETIVO ====================

// Ano Letivo - Define o período do ano letivo
model AnoLetivo {
  id              String   @id @default(cuid())
  ano             Int      @unique // Ex: 2025
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relacionamentos
  eventos EventoCalendario[]

  @@map("anos_letivos")
}

// Eventos do Calendário
model EventoCalendario {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String?
  dataInicio  DateTime
  dataFim     DateTime? // Se null, é evento de um único dia
  horaInicio  String?   // Ex: "08:00" - para eventos com horário específico
  horaFim     String?   // Ex: "17:00"
  
  // Tipo do evento - INICIO_ANO_LETIVO e FIM_ANO_LETIVO são obrigatórios e únicos por ano
  tipo        String   // INICIO_ANO_LETIVO, FIM_ANO_LETIVO, FERIADO, RECESSO, SABADO_LETIVO, EVENTO, AC, AVALIACAO, REUNIAO, CONSELHO_CLASSE, PLANEJAMENTO, FORMACAO, OUTRO
  
  // Escopo do evento
  escopo      String   @default("REDE") // REDE (toda rede), ESCOLA (específico da escola)
  
  // Recorrência
  recorrente      Boolean @default(false)
  tipoRecorrencia String? // SEMANAL, MENSAL, ANUAL
  diaRecorrencia  String? // Para semanal: "SEGUNDA", "TERCA", etc. Para mensal: "1", "15", etc.
  
  // Cor para exibição no calendário
  cor         String   @default("#3B82F6") // Cor em hexadecimal
  
  // Impacto em dias letivos
  reduzDiaLetivo Boolean @default(false) // Se true, reduz contagem de dias letivos (ex: feriados)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  anoLetivoId String
  anoLetivo   AnoLetivo @relation(fields: [anoLetivoId], references: [id], onDelete: Cascade)
  
  escolaId    String?  // Se null, aplica a toda rede
  escola      Escola?  @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  // Índices para otimização de consultas
  @@index([anoLetivoId])
  @@index([anoLetivoId, escolaId])
  @@index([anoLetivoId, dataInicio])
  @@index([dataInicio, dataFim])
  @@map("eventos_calendario")
}

// ==================== DISCIPLINAS ====================

model Disciplina {
  id                  String   @id @default(cuid())
  nome                String   // Ex: "Língua Portuguesa", "Matemática"
  codigo              String   @unique // Ex: "PORT-EF", "MAT-EF"
  descricao           String?
  cargaHorariaSemanal Int?     // Horas por semana
  obrigatoria         Boolean  @default(true)
  ativo               Boolean  @default(true)
  ordem               Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relacionamentos
  etapaId    String
  etapa      EtapaEnsino @relation(fields: [etapaId], references: [id], onDelete: Cascade)

  avaliacoes Avaliacao[]

  @@index([etapaId])
  @@map("disciplinas")
}

// ==================== CONFIGURAÇÃO DE AVALIAÇÃO ====================

model ConfiguracaoAvaliacao {
  id                          String   @id @default(cuid())
  anoLetivo                   Int
  sistemaAvaliacao            String   @default("NOTA") // NOTA, CONCEITO
  numeroPeriodos              Int      @default(4) // Bimestres
  mediaMinima                 Float    @default(6.0)
  percentualFrequenciaMinima  Float    @default(75.0)
  recuperacaoParalela         Boolean  @default(false)
  recuperacaoFinal            Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  // Escopo opcional
  escolaId String?
  escola   Escola? @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  etapaId  String?
  etapa    EtapaEnsino? @relation(fields: [etapaId], references: [id], onDelete: Cascade)

  @@index([anoLetivo])
  @@map("configuracoes_avaliacao")
}

// ==================== AVALIAÇÕES ====================

model Avaliacao {
  id           String   @id @default(cuid())
  nome         String   // Ex: "Prova Bimestral 1", "Trabalho de Português"
  tipo         String   // PROVA, TRABALHO, ATIVIDADE, PARTICIPACAO, RECUPERACAO
  peso         Float    @default(1.0)
  valorMaximo  Float    @default(10.0)
  data         DateTime
  bimestre     Int      // 1, 2, 3, 4
  observacao   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relacionamentos
  turmaId        String
  turma          Turma @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  disciplinaId   String
  disciplina     Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  profissionalId String?
  profissional   ProfissionalEducacao? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)

  notas          Nota[]

  @@index([turmaId])
  @@index([disciplinaId])
  @@index([turmaId, disciplinaId, bimestre])
  @@map("avaliacoes")
}

// ==================== NOTAS ====================

model Nota {
  id         String   @id @default(cuid())
  valor      Float    // Valor da nota (0-10 por padrão)
  observacao String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Campos adicionais para notas de recuperação (quando avaliacaoId é null)
  turmaId    String
  turma      Turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina String
  bimestre   Int    // 1-4 bimestres regulares, 5 = recuperação final

  // Relacionamentos
  avaliacaoId String?
  avaliacao   Avaliacao? @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)

  matriculaId String
  matricula   Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@unique([avaliacaoId, matriculaId])
  @@index([matriculaId])
  @@index([avaliacaoId])
  @@index([turmaId])
  @@index([turmaId, disciplina])
  @@map("notas")
}

// ==================== MÓDULO 5: PROGRAMAS ESPECIAIS ====================

// Busca Ativa Escolar - Identificação e acompanhamento de alunos faltosos/evadidos
model BuscaAtiva {
  id              String   @id @default(cuid())
  matriculaId     String
  motivo          String   // INFREQUENCIA, EVASAO, ABANDONO, RISCO_SOCIAL
  descricao       String?
  status          String   @default("ATIVA") // ATIVA, EM_ACOMPANHAMENTO, RESOLVIDA, ENCAMINHADA
  prioridade      String   @default("MEDIA") // BAIXA, MEDIA, ALTA, URGENTE

  // Responsável pelo caso
  responsavelId   String?  // ID do profissional responsável
  escolaId        String?

  // Resultado
  resultado       String?  // Descrição do resultado final
  dataResolucao   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matricula       Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  responsavel     ProfissionalEducacao? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  escola          Escola? @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  visitas         VisitaDomiciliar[]
  encaminhamentos EncaminhamentoExterno[]

  @@index([matriculaId])
  @@index([status])
  @@index([prioridade])
  @@index([escolaId])
  @@map("busca_ativa")
}

// Visitas Domiciliares realizadas
model VisitaDomiciliar {
  id             String   @id @default(cuid())
  buscaAtivaId   String
  data           DateTime
  horario        String?  // Ex: "14:30"
  responsavel    String   // Nome do profissional que realizou a visita
  situacao       String   // REALIZADA, NAO_ATENDEU, RECUSOU, MUDOU_ENDERECO
  relato         String?  // Relato detalhado da visita
  observacoes    String?
  proximaVisita  DateTime? // Data da próxima visita agendada

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  buscaAtiva     BuscaAtiva @relation(fields: [buscaAtivaId], references: [id], onDelete: Cascade)

  @@index([buscaAtivaId])
  @@index([data])
  @@map("visitas_domiciliares")
}

// Encaminhamentos externos (Conselho Tutelar, assistência social, saúde, etc.)
model EncaminhamentoExterno {
  id             String   @id @default(cuid())
  buscaAtivaId   String
  orgao          String   // CONSELHO_TUTELAR, ASSISTENCIA_SOCIAL, SAUDE, CREAS, CRAS, MINISTERIO_PUBLICO
  motivo         String
  dataEnvio      DateTime
  protocolo      String?  // Número do protocolo
  status         String   @default("ENVIADO") // ENVIADO, EM_ANALISE, ATENDIDO, NAO_ATENDIDO
  retorno        String?  // Resposta do órgão
  dataRetorno    DateTime?
  observacoes    String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  buscaAtiva     BuscaAtiva @relation(fields: [buscaAtivaId], references: [id], onDelete: Cascade)

  @@index([buscaAtivaId])
  @@index([orgao])
  @@index([status])
  @@map("encaminhamentos_externos")
}

// Plano Educacional Individualizado (PEI) - Educação Especial/AEE
model PlanoEducacionalIndividualizado {
  id                  String   @id @default(cuid())
  matriculaId         String   @unique
  anoLetivo           Int

  // Identificação
  deficiencia         String   // Tipo de deficiência ou necessidade especial
  cid                 String?  // Código CID da condição
  laudoMedico         Boolean  @default(false)
  laudoPath           String?  // Path para o laudo médico

  // Atendimento
  necessitaAEE        Boolean  @default(false)
  frequenciaAEE       String?  // Ex: "2x por semana"
  profissionalAEE     String?  // Nome do professor do AEE

  // Objetivos e Ações
  objetivosGerais     String?  // Objetivos gerais do PEI
  objetivosEspecificos String? // Objetivos específicos
  estrategias         String?  // Estratégias pedagógicas
  recursos            String?  // Recursos e adaptações necessárias
  avaliacaoDiagnostica String? // Avaliação diagnóstica inicial

  // Participantes
  elaboradoPor        String?  // Profissionais que elaboraram
  dataElaboracao      DateTime @default(now())
  dataRevisao         DateTime?

  // Status
  status              String   @default("ATIVO") // ATIVO, REVISADO, FINALIZADO

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  matricula           Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  atendimentos        AtendimentoAEE[]

  @@index([matriculaId])
  @@index([anoLetivo])
  @@index([status])
  @@map("planos_educacionais_individualizados")
}

// Sala de Recursos (Atendimento Educacional Especializado)
model SalaRecursos {
  id                String   @id @default(cuid())
  escolaId          String
  nome              String   // Ex: "Sala de Recursos Multifuncionais"
  tipo              String   // TIPO_I, TIPO_II (DV/DA/Surdocegueira)
  turno             String   // MATUTINO, VESPERTINO, NOTURNO, INTEGRAL
  capacidade        Int      @default(10)
  ativa             Boolean  @default(true)

  // Recursos disponíveis
  recursos          String?  // Lista de recursos/equipamentos disponíveis

  // Profissionais
  profissionais     String?  // IDs dos profissionais (JSON array)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  escola            Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)
  atendimentos      AtendimentoAEE[]

  @@index([escolaId])
  @@index([turno])
  @@map("salas_recursos")
}

// Atendimentos AEE realizados
model AtendimentoAEE {
  id             String   @id @default(cuid())
  peiId          String
  salaRecursosId String
  data           DateTime
  horario        String?  // Ex: "14:00"
  duracao        Int?     // Duração em minutos

  // Conteúdo do atendimento
  objetivo       String?  // Objetivo do atendimento
  atividades     String?  // Atividades realizadas
  recursos       String?  // Recursos utilizados
  observacoes    String?  // Observações sobre o desenvolvimento

  // Presença
  presenca       Boolean  @default(true)
  justificativa  String?  // Se faltou, justificativa

  profissionalId String?  // Profissional que realizou o atendimento

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pei            PlanoEducacionalIndividualizado @relation(fields: [peiId], references: [id], onDelete: Cascade)
  salaRecursos   SalaRecursos @relation(fields: [salaRecursosId], references: [id], onDelete: Cascade)
  profissional   ProfissionalEducacao? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)

  @@index([peiId])
  @@index([salaRecursosId])
  @@index([data])
  @@map("atendimentos_aee")
}

// Acompanhamento Individualizado (para qualquer aluno que necessite)
model AcompanhamentoIndividualizado {
  id              String   @id @default(cuid())
  matriculaId     String
  tipo            String   // PEDAGOGICO, COMPORTAMENTAL, SOCIO_EMOCIONAL, APRENDIZAGEM
  motivo          String   // Motivo do acompanhamento
  objetivos       String?  // Objetivos do acompanhamento

  // Responsável
  profissionalId  String?  // Professor/coordenador responsável
  escolaId        String?

  // Ações e estratégias
  acoes           String?  // Ações realizadas
  estrategias     String?  // Estratégias utilizadas

  // Datas
  dataInicio      DateTime @default(now())
  dataFim         DateTime?

  // Evolução
  evolucoes       String?  // Registros de evolução (JSON array)

  // Status
  status          String   @default("EM_ANDAMENTO") // EM_ANDAMENTO, CONCLUIDO, SUSPENSO
  resultado       String?  // Resultado final do acompanhamento

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matricula       Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  profissional    ProfissionalEducacao? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)
  escola          Escola? @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  @@index([matriculaId])
  @@index([tipo])
  @@index([status])
  @@index([escolaId])
  @@map("acompanhamentos_individualizados")
}

// ==================== COMUNICAÇÃO E EVENTOS (MÓDULO 9) ====================

// Plantão Pedagógico - Atendimento aos pais/responsáveis
model PlantaoPedagogico {
  id              String   @id @default(cuid())
  escolaId        String
  data            DateTime
  tipo            String   // INDIVIDUAL, COLETIVO, POR_TURMA
  descricao       String?

  // Horários
  horarioInicio   String   // Ex: "14:00"
  horarioFim      String   // Ex: "17:00"

  // Participantes
  profissionais   String?  // IDs dos profissionais disponíveis (JSON array)
  turmaId         String?  // Se for específico de uma turma

  // Local
  local           String?  // Sala, auditório, etc.

  // Observações
  observacoes     String?
  ativo           Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  escola          Escola   @relation("PlantaoEscola", fields: [escolaId], references: [id], onDelete: Cascade)
  turma           Turma?   @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  @@index([escolaId])
  @@index([data])
  @@index([turmaId])
  @@map("plantoes_pedagogicos")
}

// Reunião de Pais e Mestres
model ReuniaoPais {
  id              String   @id @default(cuid())
  escolaId        String
  turmaId         String?  // Se null, é reunião geral da escola

  // Informações básicas
  titulo          String
  descricao       String?
  data            DateTime
  horario         String   // Ex: "19:00"
  duracao         Int?     // Duração estimada em minutos
  local           String?  // Auditório, sala, etc.

  // Tipo e finalidade
  tipo            String   // BIMESTRAL, TRIMESTRAL, EXTRAORDINARIA, CONSELHO_PARTICIPATIVO
  finalidade      String?  // Assuntos principais a serem tratados

  // Pauta
  pauta           String?  // Itens da pauta (pode ser JSON array)

  // Ata
  ata             String?  // Ata da reunião (preenchida depois)
  encaminhamentos String?  // Encaminhamentos e decisões

  // Status
  status          String   @default("AGENDADA") // AGENDADA, REALIZADA, CANCELADA

  // Responsável
  profissionalId  String?  // Coordenador/diretor responsável

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  escola          Escola   @relation("ReuniaoEscola", fields: [escolaId], references: [id], onDelete: Cascade)
  turma           Turma?   @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  profissional    ProfissionalEducacao? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)

  presencas       PresencaReuniao[]

  @@index([escolaId])
  @@index([turmaId])
  @@index([data])
  @@index([status])
  @@map("reunioes_pais")
}

// Presença em Reuniões
model PresencaReuniao {
  id              String   @id @default(cuid())
  reuniaoId       String
  matriculaId     String   // Aluno relacionado
  nomeResponsavel String   // Nome do responsável que compareceu
  parentesco      String?  // Pai, mãe, avó, etc.
  presente        Boolean  @default(false)
  horarioChegada  String?  // Ex: "19:15"
  observacoes     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reuniao         ReuniaoPais @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  matricula       Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

  @@index([reuniaoId])
  @@index([matriculaId])
  @@unique([reuniaoId, matriculaId]) // Um registro por aluno por reunião
  @@map("presencas_reunioes")
}

// Comunicados Gerais
model Comunicado {
  id              String   @id @default(cuid())
  escolaId        String?  // Se null, é comunicado da SEMEC para toda rede

  // Conteúdo
  titulo          String
  mensagem        String   // Conteúdo do comunicado
  tipo            String   // INFORMATIVO, URGENTE, AVISO, CONVITE, ALERTA

  // Categorização
  categoria       String?  // ACADEMICO, ADMINISTRATIVO, EVENTO, SAUDE, TRANSPORTE, ALIMENTACAO, GERAL

  // Destinatários
  destinatarios   String   // TODOS, PAIS, PROFESSORES, FUNCIONARIOS, ALUNOS, TURMA_ESPECIFICA, ETAPA_ESPECIFICA
  turmaId         String?  // Se destinatário for turma específica
  etapaId         String?  // Se destinatário for etapa específica

  // Anexos
  anexoUrl        String?  // URL de arquivo anexo (PDF, imagem, etc.)

  // Publicação
  dataPublicacao  DateTime @default(now())
  dataExpiracao   DateTime? // Data em que o comunicado expira
  ativo           Boolean  @default(true)
  destaque        Boolean  @default(false) // Se deve ser destacado

  // Autor
  autorId         String?  // Profissional que criou
  autorNome       String   // Nome do autor/setor

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  escola          Escola?  @relation("ComunicadoEscola", fields: [escolaId], references: [id], onDelete: Cascade)
  turma           Turma?   @relation(fields: [turmaId], references: [id], onDelete: SetNull)
  etapa           EtapaEnsino? @relation(fields: [etapaId], references: [id], onDelete: SetNull)
  autor           ProfissionalEducacao? @relation(fields: [autorId], references: [id], onDelete: SetNull)

  destinatariosLeitura ComunicadoDestinatario[]

  @@index([escolaId])
  @@index([tipo])
  @@index([dataPublicacao])
  @@index([turmaId])
  @@index([etapaId])
  @@map("comunicados")
}

// Controle de leitura de comunicados
model ComunicadoDestinatario {
  id            String    @id @default(cuid())
  comunicadoId  String
  userId        String    // Usuário que recebeu

  // Status de leitura
  lido          Boolean   @default(false)
  dataLeitura   DateTime?

  // Confirmação (para comunicados que exigem confirmação)
  confirmado    Boolean   @default(false)
  dataConfirmacao DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  comunicado    Comunicado @relation(fields: [comunicadoId], references: [id], onDelete: Cascade)

  @@index([comunicadoId])
  @@index([userId])
  @@unique([comunicadoId, userId]) // Um registro por usuário por comunicado
  @@map("comunicados_destinatarios")
}

// Sistema de Notificações
model Notificacao {
  id            String    @id @default(cuid())
  userId        String    // Destinatário

  // Conteúdo
  titulo        String
  mensagem      String
  tipo          String    // SISTEMA, ACADEMICO, FINANCEIRO, COMUNICADO, LEMBRETE, URGENTE

  // Prioridade
  prioridade    String    @default("NORMAL") // BAIXA, NORMAL, ALTA, URGENTE

  // Canais de envio
  canais        String    // JSON array: ["APP", "EMAIL", "SMS", "PUSH"]

  // Link/Ação
  link          String?   // Link para mais detalhes ou ação
  acaoTipo      String?   // VISUALIZAR_COMUNICADO, CONFIRMAR_PRESENCA, VER_BOLETIM, etc.
  acaoId        String?   // ID do recurso relacionado

  // Status
  lida          Boolean   @default(false)
  dataLeitura   DateTime?
  enviadaEmail  Boolean   @default(false)
  enviadaSMS    Boolean   @default(false)
  enviadaPush   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([tipo])
  @@index([lida])
  @@index([createdAt])
  @@map("notificacoes")
}

// ==================== OBSERVABILIDADE E MONITORAMENTO ====================

// Logs de requisições HTTP
model RequestLog {
  id            String    @id @default(cuid())
  
  // Request
  method        String    // GET, POST, PUT, DELETE
  path          String    // /api/matriculas
  query         String?   // Query string
  statusCode    Int       // 200, 404, 500, etc.
  
  // Timing
  duration      Int       // Tempo de resposta em ms
  timestamp     DateTime  @default(now())
  
  // Usuario
  userId        String?
  userEmail     String?
  userRole      String?
  
  // Request/Response
  requestBody   String?   // JSON do body (opcional)
  responseBody  String?   // JSON da resposta (apenas erros)
  errorMessage  String?   // Mensagem de erro se houver
  errorStack    String?   // Stack trace se houver erro
  
  // Metadata
  ip            String?
  userAgent     String?
  module        String?   // MATRICULAS, PROFISSIONAIS, TURMAS, etc.
  
  // Indices para queries rápidas
  @@index([path])
  @@index([method])
  @@index([statusCode])
  @@index([timestamp])
  @@index([userId])
  @@index([module])
  @@map("request_logs")
}

// Métricas agregadas por rota
model RouteMetrics {
  id            String    @id @default(cuid())
  
  // Identificação
  method        String    // GET, POST, PUT, DELETE
  path          String    // /api/matriculas
  module        String?   // MATRICULAS, PROFISSIONAIS, etc.
  
  // Estatísticas do dia
  date          DateTime  // Data do dia (00:00:00)
  
  // Contadores
  totalRequests Int       @default(0)
  successCount  Int       @default(0)  // Status 2xx
  errorCount    Int       @default(0)  // Status 4xx + 5xx
  error4xxCount Int       @default(0)  // Status 4xx
  error5xxCount Int       @default(0)  // Status 5xx
  
  // Timing
  avgDuration   Float     @default(0)  // Média em ms
  minDuration   Int       @default(0)  // Mínimo em ms
  maxDuration   Int       @default(0)  // Máximo em ms
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([method, path, date])
  @@index([date])
  @@index([module])
  @@index([totalRequests])
  @@map("route_metrics")
}

// Erros registrados
model ErrorLog {
  id            String    @id @default(cuid())
  
  // Classificação
  type          String    // API_ERROR, DATABASE_ERROR, VALIDATION_ERROR, etc.
  severity      String    // LOW, MEDIUM, HIGH, CRITICAL
  module        String?   // MATRICULAS, PROFISSIONAIS, etc.
  
  // Error details
  message       String
  stack         String?
  code          String?   // Error code se houver
  
  // Context
  path          String?
  method        String?
  userId        String?
  requestData   String?   // JSON dos dados da requisição
  
  // Metadata
  count         Int       @default(1) // Quantas vezes ocorreu
  firstSeen     DateTime  @default(now())
  lastSeen      DateTime  @default(now())
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  notes         String?   // Notas sobre a resolução
  
  @@index([type])
  @@index([severity])
  @@index([module])
  @@index([resolved])
  @@index([lastSeen])
  @@map("error_logs")
}

// Métricas do sistema
model SystemMetrics {
  id            String    @id @default(cuid())
  
  // Timestamp
  timestamp     DateTime  @default(now())
  
  // Performance
  uptime        Int       // Segundos desde último restart
  memoryUsage   Float     // MB
  cpuUsage      Float     // Percentual
  
  // Database
  dbConnections Int       // Conexões ativas
  dbQueryTime   Float     // Tempo médio de query em ms
  
  // API
  requestsPerMin Int      // Requests por minuto
  avgResponseTime Float   // Tempo médio de resposta em ms
  errorRate     Float     // Taxa de erro (0-100%)
  
  // Health status
  status        String    // HEALTHY, DEGRADED, DOWN
  
  @@index([timestamp])
  @@map("system_metrics")
}
