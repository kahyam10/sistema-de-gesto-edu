# URL da API do Sistema de Gestão Educacional
# Em desenvolvimento: http://localhost:3333
# Em produção: https://sua-api.exemplo.com
API_URL=http://localhost:3333

# Token JWT para autenticação
# Obtenha este token fazendo login na API (/api/auth/login)
# O token deve ser um JWT válido gerado pelo sistema
API_TOKEN=seu_token_jwt_aqui
