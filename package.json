{
  "name": "sistema-gestao-educacional",
  "version": "1.0.0",
  "description": "Sistema de Gestão Educacional - Prefeitura de Ibirapitanga-BA",
  "private": true,
  "workspaces": [
    "backend",
    "dashboard"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build --workspace=backend",
    "build:dashboard": "npm run build --workspace=dashboard",
    "start": "concurrently \"npm run start:backend\" \"npm run start:dashboard\"",
    "start:backend": "npm run start --workspace=backend",
    "start:dashboard": "npm run start --workspace=dashboard",
    "db:push": "npm run db:push --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend"
  },
  "keywords": [
    "educacao",
    "gestao",
    "ibirapitanga"
  ],
  "author": "Prefeitura de Ibirapitanga-BA",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
